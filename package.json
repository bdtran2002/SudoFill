{
  "name": "sudofill",
  "description": "Temporary identity and email extension",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "wxt -b firefox",
    "dev:firefox": "wxt -b firefox",
    "dev:chrome": "wxt",
    "dev:test": "bun run typecheck && bun run test && bun run build",
    "build": "wxt build -b firefox",
    "build:firefox": "wxt build -b firefox",
    "build:chrome": "wxt build",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:chrome": "wxt zip",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release:check": "node scripts/verify-release-version.mjs",
    "firefox-addon:check": "bun run build:firefox && node scripts/sync-firefox-addon-bundle.mjs",
    "firefox-addon:sync": "bun run build:firefox && node scripts/sync-firefox-addon-bundle.mjs --sync",
    "release:check:artifacts": "node scripts/verify-release-version.mjs --check-generated",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.511.0",
    "neverthrow": "^8.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/chrome": "^0.1.40",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.4",
    "wxt": "^0.20.24"
  }
}
